---
// Strategy index grouped by category (ARCHITECTURE.md: trend, mean reversion,
// optimization, risk, infra). Drafts are visible in dev only.
import Base from '../../layouts/Base.astro';
import Badge from '../../components/Badge.astro';
import { getCollection } from 'astro:content';

const CATEGORY_ORDER = ['trend', 'mean reversion', 'optimization', 'risk', 'infra'] as const;

const entries = (
  await getCollection('strategies', ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const groups = CATEGORY_ORDER.map((category) => ({
  category,
  entries: entries.filter((entry) => entry.data.category === category),
})).filter((group) => group.entries.length > 0);
---

<Base
  title="strategies · roy yang"
  description="A working notebook of implemented and tested trading techniques."
>
  <h1>Strategies</h1>
  {
    groups.map((group) => (
      <section>
        <h2 class="section-label">{group.category}</h2>
        {group.entries.map((entry) => (
          <div class="post-row">
            <span>
              <a href={`/strategies/${entry.slug}/`}>{entry.data.title}</a>{' '}
              <Badge status={entry.data.status} />
            </span>
            <time datetime={entry.data.date.toISOString()}>
              {entry.data.date.toISOString().slice(0, 10)}
            </time>
          </div>
        ))}
      </section>
    ))
  }
</Base>
