---
// Blog post pages, rendered through the Post layout (PLAN Phase 3).
import Post from '../../layouts/Post.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (
    await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft)
  ).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: index > 0 ? posts[index - 1] : undefined,
      next: index < posts.length - 1 ? posts[index + 1] : undefined,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await post.render();
---

<Post post={post} headings={headings} prev={prev} next={next}>
  <Content />
</Post>
